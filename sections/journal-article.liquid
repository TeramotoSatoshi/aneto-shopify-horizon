{{ 'journal.css' | asset_url | stylesheet_tag }}

<article class="journal-article">
  {%- comment -%} Header {%- endcomment -%}
  <header class="journal-article__header">
    {%- if article.tags.size > 0 -%}
      <p class="journal-article__category">{{ article.tags | first }}</p>
    {%- endif -%}
    <h1 class="journal-article__title">{{ article.title }}</h1>
    <time class="journal-article__date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
      {{ article.published_at | date: '%Y.%m.%d' }}
    </time>
  </header>

  {%- comment -%} Featured Image {%- endcomment -%}
  {%- if article.image -%}
    <div class="journal-article__hero">
      {{
        article.image
        | image_url: width: 1600
        | image_tag:
          loading: 'eager',
          sizes: '(min-width: 840px) 800px, calc(100vw - 40px)',
          widths: '480,720,960,1200,1600'
      }}
    </div>
  {%- endif -%}

  {%- comment -%} Article Content {%- endcomment -%}
  <div class="journal-article__content rte">
    {{ article.content }}
  </div>

  {%- comment -%} Share Links {%- endcomment -%}
  <div class="journal-article__share">
    <a
      href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ article.url | url_encode }}&text={{ article.title | url_encode }}"
      target="_blank"
      rel="noopener noreferrer"
      class="journal-article__share-link"
      aria-label="Share on X"
    >
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
    </a>
    <a
      href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ article.url | url_encode }}"
      target="_blank"
      rel="noopener noreferrer"
      class="journal-article__share-link"
      aria-label="Share on Facebook"
    >
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
      </svg>
    </a>
    <a
      href="https://line.me/R/msg/text/?{{ article.title | url_encode }}%0A{{ shop.url }}{{ article.url | url_encode }}"
      target="_blank"
      rel="noopener noreferrer"
      class="journal-article__share-link"
      aria-label="Share on LINE"
    >
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.271.175-.508.433-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63.349 0 .631.285.631.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
      </svg>
    </a>
  </div>

  {%- comment -%} Navigation {%- endcomment -%}
  <nav class="journal-article__nav">
    <a href="{{ blog.url }}" class="journal-article__nav-link">
      ← Back
    </a>
    {%- if blog.next_article -%}
      <a href="{{ blog.next_article }}" class="journal-article__nav-link">
        Next →
      </a>
    {%- elsif blog.previous_article -%}
      <a href="{{ blog.previous_article }}" class="journal-article__nav-link">
        Prev →
      </a>
    {%- endif -%}
  </nav>
</article>

<script type="application/ld+json">
  {{ article | structured_data }}
</script>

{% schema %}
{
  "name": "Journal Article",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Journal Article"
    }
  ]
}
{% endschema %}
